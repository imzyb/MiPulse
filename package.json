{
  "name": "mipulse",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:vite": "vite --port 5173",
    "dev:wrangler": "npx wrangler dev --port 8787 --test-scheduled",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:wrangler\"",
    "build": "vite build",
    "deploy": "node scripts/deploy.js",
    "deploy:full": "node scripts/deploy.js",
    "db:create": "npx wrangler d1 create MIPULSE_DB",
    "db:init": "npx wrangler d1 execute MIPULSE_DB --file=./schema.sql",
    "db:init:remote": "npx wrangler d1 execute MIPULSE_DB --file=./schema.sql --remote",
    "test": "node --test test/**/*.test.js",
    "preview": "vite preview",
    "wrangler": "npx wrangler"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "hono": "^4.12.10",
    "jose": "^5.2.1",
    "lucide-vue-next": "^0.321.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.3",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.12",
    "wrangler": "^4.81.0"
  }
}
