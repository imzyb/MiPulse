name = "mipulse"
main = "functions/api/[[path]].js"
type = "service"
compatibility_date = "2024-03-31"

# Cloudflare Account Configuration
# 从 https://dash.cloudflare.com/ → Settings → Account ID 获取
account_id = "your-account-id-here"
workers_dev = true

# ============================================================================
# Development Environment Configuration
# ============================================================================
[env.development]
vars = { ENVIRONMENT = "development" }

# D1 Database Binding - Development
# 使用开发环境的D1数据库ID
[[env.development.d1_databases]]
binding = "MIPULSE_DB"
database_name = "mipulse"
database_id = "your-dev-d1-id"

# KV Namespace Binding - Development
# 运行: wrangler kv:namespace create "MIPULSE_KV" --env development
[[env.development.kv_namespaces]]
binding = "MIPULSE_KV"
id = "your-dev-kv-id"
preview_id = "your-dev-kv-preview-id"

# ============================================================================
# Production Environment Configuration
# ============================================================================
[env.production]
# 如果使用自定义域名，填入您的域名路由和Zone ID
route = "your-domain.com/api/*"
zone_id = "your-zone-id"
vars = { ENVIRONMENT = "production" }

# D1 Database Binding - Production
# 从 Cloudflare Dashboard → Workers → D1 → mipulse 获取ID
[[env.production.d1_databases]]
binding = "MIPULSE_DB"
database_name = "mipulse"
database_id = "your-prod-d1-id"

# KV Namespace Binding - Production
# 运行: wrangler kv:namespace create "MIPULSE_KV"
[[env.production.kv_namespaces]]
binding = "MIPULSE_KV"
id = "your-prod-kv-id"
preview_id = "your-prod-kv-preview-id"

# ============================================================================
# Cron Triggers - Optional but Recommended (可选但强烈推荐)
# ============================================================================
# 启用后会每5分钟自动检测离线节点，发送恢复通知
# 这会将D1查询减少96%，强烈建议启用

[[triggers.crons]]
crons = ["*/5 * * * *"]

# ============================================================================
# Build Configuration
# ============================================================================
[build]
command = "npm install && npm run build"
cwd = "./"
watch_paths = ["src/**/*.js", "src/**/*.vue", "functions/**/*.js"]

[build.upload]
format = "service-worker"
main = "./functions/api/[[path]].js"

# ============================================================================
# Development Server Configuration
# ============================================================================
[dev]
ip = "127.0.0.1"
port = 8787
local_protocol = "http"

# ============================================================================
# 快速设置指南
# ============================================================================
#
# 1. 获取 Account ID
#    https://dash.cloudflare.com/ → Settings → Account ID
#
# 2. 创建/获取 D1 数据库 ID
#    a) 已有数据库: Cloudflare Dashboard → Workers → D1 → mipulse → 复制 Database ID
#    b) 新建数据库: wrangler d1 create mipulse
#
# 3. 创建 KV 命名空间
#    wrangler kv:namespace create "MIPULSE_KV"
#    wrangler kv:namespace create "MIPULSE_KV" --preview
#    複製输出的 id 和 preview_id
#
# 4. 填充此文件中的所有 "your-xxx-here" 占位符
#
# 5. 运行部署
#    npm run build
#    wrangler pages deploy dist --env production
#
# 更多帮助请查看: QUICK_DEPLOY_GUIDE.md 或运行 ./setup.sh 脚本
