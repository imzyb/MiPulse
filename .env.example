# MiPulse 环境变量配置示例
# 复制此文件为 .env.local 并填入您的实际值

# ========================================
# Cloudflare Configuration
# ========================================

# Cloudflare Account ID
# 从 https://dash.cloudflare.com → Settings → Account ID 获取
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API Token
# 从 https://dash.cloudflare.com → Account Settings → API Tokens 获取
CLOUDFLARE_API_TOKEN=

# ========================================
# D1 Database Configuration
# ========================================

# 生产环境 D1 数据库 ID
PROD_D1_DATABASE_ID=

# 开发环境 D1 数据库 ID
DEV_D1_DATABASE_ID=

# ========================================
# KV Namespace Configuration
# ========================================

# 生产环境 KV 命名空间 ID
PROD_KV_NAMESPACE_ID=

# 生产环境 KV 命名空间预览 ID
PROD_KV_NAMESPACE_PREVIEW_ID=

# 开发环境 KV 命名空间 ID
DEV_KV_NAMESPACE_ID=

# 开发环境 KV 命名空间预览 ID
DEV_KV_NAMESPACE_PREVIEW_ID=

# ========================================
# 自定义域名 (可选)
# ========================================

# 如果使用自定义域名，填入此项
CUSTOM_DOMAIN=

# Zone ID (当使用自定义域名时需要)
CLOUDFLARE_ZONE_ID=

# ========================================
# Cron 触发器配置 (可选)
# ========================================

# 启用 Cron 触发器进行异步离线检测
# 值: true 或 false
ENABLE_CRON_TRIGGERS=true

# Cron 表达式 (离线检测频率)
# 默认: */5 * * * * (每5分钟)
CRON_SCHEDULE="*/5 * * * *"

# ========================================
# 部署配置
# ========================================

# 部署环境
# 值: production 或 development
DEPLOY_ENV=production

# 是否启用部署后测试
RUN_POST_DEPLOY_TESTS=true

# ========================================
# 日志配置
# ========================================

# 日志级别
# 值: debug, info, warn, error
LOG_LEVEL=info

# 是否在控制台输出详细日志
VERBOSE_LOGGING=false
